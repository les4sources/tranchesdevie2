<div class="flex flex-col gap-4">
  <div class="flex items-center justify-between">
    <p class="text-sm font-semibold text-ink-900">Panier</p>
    <span class="text-xs font-medium text-ink-500">
      <% if count.zero? %>
        Aucun article
      <% else %>
        <%= count %> <%= count > 1 ? "produits" : "produit" %>
      <% end %>
    </span>
  </div>

  <% if items.any? %>
    <div class="flex max-h-64 flex-col gap-3 overflow-y-auto pr-1">
      <% items.each do |item| %>
        <div class="flex items-start justify-between gap-3 rounded-md bg-flour-100 px-3 py-2">
          <div class="flex flex-col">
            <span class="text-sm font-semibold text-ink-900"><%= item[:product_name] %></span>
            <span class="text-xs text-ink-700"><%= item[:variant_name] %></span>
            <span class="text-xs text-ink-500">Qté&nbsp;: <%= item[:qty] %></span>
          </div>
          <span class="text-sm font-semibold text-ink-900">
            <%= number_to_currency(item[:total_cents].to_f / 100, unit: "€", separator: ",", delimiter: "") %>
          </span>
        </div>
      <% end %>
    </div>

    <div class="space-y-2 border-t border-flour-300 pt-4">
      <div class="flex items-center justify-between text-sm text-ink-700">
        <span>Sous-total</span>
        <span><%= number_to_currency((subtotal_cents || total_cents).to_f / 100, unit: "€", separator: ",", delimiter: "") %></span>
      </div>
      <% if discount_cents.to_i > 0 %>
        <div class="flex items-center justify-between text-sm text-success-700">
          <span>Remise<% if customer&.effective_discount_percent.to_i.positive? %> (<%= customer.effective_discount_percent %>%)<% end %></span>
          <span>-<%= number_to_currency(discount_cents.to_f / 100, unit: "€", separator: ",", delimiter: "") %></span>
        </div>
      <% end %>
      <div class="flex items-center justify-between">
        <span class="text-sm font-medium text-ink-700">Total estimé</span>
        <span class="text-base font-bold text-ink-900">
          <%= number_to_currency(total_cents.to_f / 100, unit: "€", separator: ",", delimiter: "") %>
        </span>
      </div>
    </div>
  <% else %>
    <p class="rounded-md bg-flour-100 px-3 py-4 text-sm text-ink-700">
      Votre panier est vide pour le moment.
    </p>
  <% end %>

  <a href="<%= cart_path %>" class="flex items-center justify-center gap-2 rounded-md bg-sage-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sage-500">
    <%= lucide "shopping-basket", size: 16, color: "#fff" %>
    Voir le panier
  </a>
</div>
