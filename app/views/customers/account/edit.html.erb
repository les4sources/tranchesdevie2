<% content_for :title, "Modifier mon profil" %>

<div class="mx-auto w-full max-w-2xl">
  <h1 class="mb-6 font-script text-4xl font-bold text-ink-900 sm:text-5xl">Modifier mon profil</h1>

  <div class="rounded-lg border border-flour-300 bg-warm-white p-6 shadow-sm">
    <%= form_with model: @customer, url: customers_account_path, local: true do |f| %>
      <% if @customer.errors.any? %>
        <div class="mb-4 rounded-md border border-danger-200 bg-danger-100 p-4">
          <ul class="list-inside list-disc text-sm text-danger-700">
            <% @customer.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-4">
        <div>
          <%= f.label :first_name, "Prénom", class: "mb-2 block text-[13px] font-medium text-ink-700" %>
          <%= f.text_field :first_name,
              value: @customer.first_name,
              class: "h-12 w-full rounded-md border border-flour-400 bg-white px-3 text-[15px] text-ink-900 shadow-[inset_0_1px_2px_rgba(74,60,38,0.06)] focus:border-sage-600 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]",
              required: true %>
        </div>

        <div>
          <%= f.label :last_name, "Nom", class: "mb-2 block text-[13px] font-medium text-ink-700" %>
          <%= f.text_field :last_name,
              value: @customer.last_name,
              class: "h-12 w-full rounded-md border border-flour-400 bg-white px-3 text-[15px] text-ink-900 shadow-[inset_0_1px_2px_rgba(74,60,38,0.06)] focus:border-sage-600 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]" %>
        </div>

        <div data-controller="phone-input" data-phone-input-default-country-value="BE">
          <%= f.label :phone_e164, "Numéro de GSM", class: "mb-2 block text-[13px] font-medium text-ink-700" %>
          <div class="relative">
            <%= f.text_field :phone_e164,
                value: @customer.phone_e164,
                data: {
                  phone_input_target: "input"
                },
                class: "h-12 w-full rounded-md border border-flour-400 bg-white pl-3 pr-24 text-[15px] text-ink-900 shadow-[inset_0_1px_2px_rgba(74,60,38,0.06)] focus:border-sage-600 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]",
                required: true,
                pattern: "\\+[1-9]\\d{1,14}",
                autocomplete: "tel" %>
            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
              <span
                data-phone-input-target="flag"
                class="text-xl">
                🇧🇪
              </span>
            </div>
          </div>
        </div>

        <div>
          <%= f.label :email, "Adresse e-mail", class: "mb-2 block text-[13px] font-medium text-ink-700" %>
          <%= f.email_field :email,
              value: @customer.email,
              class: "h-12 w-full rounded-md border border-flour-400 bg-white px-3 text-[15px] text-ink-900 shadow-[inset_0_1px_2px_rgba(74,60,38,0.06)] focus:border-sage-600 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]" %>
        </div>

        <div class="flex items-center gap-2">
          <%= f.check_box :sms_opt_out,
              checked: @customer.sms_opt_out,
              class: "h-[18px] w-[18px] rounded accent-sage-600" %>
          <%= f.label :sms_opt_out, "Désactiver les notifications par SMS", class: "block text-sm text-ink-700" %>
        </div>
        <p class="text-sm text-ink-500">Décoche cette case pour recevoir des notifications par SMS concernant tes commandes.</p>

        <div class="flex items-center gap-2">
          <%= f.check_box :email_opt_out,
              checked: @customer.email_opt_out,
              class: "h-[18px] w-[18px] rounded accent-sage-600" %>
          <%= f.label :email_opt_out, "Désactiver les e-mails (hors codes de connexion)", class: "block text-sm text-ink-700" %>
        </div>
        <p class="text-sm text-ink-500">Décoche cette case pour recevoir nos e-mails (confirmations de commande, etc.). Les codes de connexion par e-mail sont toujours envoyés.</p>
      </div>

      <div class="mt-6 flex gap-3">
        <%= f.submit "Enregistrer", class: "cursor-pointer rounded-md bg-sage-600 px-5 py-2.5 text-sm font-semibold text-white shadow-xs transition hover:bg-sage-500 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]" %>
        <%= link_to "Annuler", customers_account_path, class: "rounded-md border border-flour-400 bg-warm-white px-5 py-2.5 text-sm font-semibold text-ink-700 shadow-xs transition hover:bg-flour-100" %>
      </div>
    <% end %>
  </div>
</div>
