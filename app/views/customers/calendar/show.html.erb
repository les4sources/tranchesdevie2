<% content_for :title, "Mon calendrier" %>

<div class="w-full" data-controller="calendar calendar-intro"
     data-calendar-wallet-balance-value="<%= @wallet.balance_cents %>"
     data-calendar-committed-value="<%= @committed_cents %>"
     data-calendar-reload-url-value="<%= customers_wallet_reload_path %>"
     data-calendar-skip-wallet-value="<%= current_customer.skip_wallet_check? %>"
     data-calendar-intro-auto-open-value="<%= current_customer.calendar_intro_seen_at.nil? %>"
     data-calendar-intro-mark-seen-url-value="<%= calendar_intro_seen_path %>"
>
  <div class="mb-7 flex flex-wrap items-end justify-between gap-3">
    <div>
      <div class="tdv-eyebrow mb-1.5 text-sage-700">Planifie tes fournées</div>
      <h1 class="font-script text-4xl font-bold text-ink-900 sm:text-5xl">Mon calendrier</h1>
    </div>
    <div class="flex items-center gap-2.5">
      <button type="button"
              class="inline-flex items-center gap-1.5 rounded-md px-3 py-2 text-sm font-semibold text-ink-700 transition hover:bg-flour-200"
              data-action="click->calendar-intro#open"
              aria-label="Comment ça marche ?">
        <%= lucide "info", size: 16, color: "var(--ink-700)" %>
        <span class="hidden sm:inline">Comment ça marche ?</span>
      </button>
      <%= link_to "Mon compte", customers_account_path, class: "rounded-md border border-flour-400 bg-warm-white px-4 py-2 text-sm font-semibold text-ink-700 shadow-xs transition hover:bg-warm-white-2" %>
      <%= link_to customers_wallet_path, class: "inline-flex items-center gap-1.5 rounded-md bg-sage-600 px-4 py-2 text-sm font-semibold text-white shadow-xs transition hover:bg-sage-500" do %>
        <%= lucide "wallet", size: 16, color: "#fff" %> Portefeuille
      <% end %>
    </div>
  </div>

  <% unless current_customer.skip_wallet_check? %>
    <!-- Solde du portefeuille -->
    <div class="mb-7 overflow-hidden rounded-lg border border-flour-300 bg-warm-white shadow-xs">
      <div class="flex flex-col items-stretch sm:flex-row sm:items-center">
        <div class="flex-1 px-5 py-4">
          <div class="mb-1.5 text-[13px] font-medium text-ink-500">Solde du portefeuille</div>
          <div class="text-[22px] font-bold text-ink-900"><%= number_to_currency(@wallet.balance_euros, unit: "€", format: "%n %u") %></div>
          <% if @committed_cents > 0 %>
            <div class="mt-1 text-[13px] text-ink-500">− <%= number_to_currency(@committed_cents / 100.0, unit: "€", format: "%n %u") %> engagé sur commandes planifiées</div>
          <% end %>
        </div>
        <div class="h-px w-full bg-flour-300 sm:h-12 sm:w-px"></div>
        <div class="flex-1 px-5 py-4">
          <div class="mb-1.5 text-[13px] font-medium text-ink-500">Disponible pour commander</div>
          <div class="text-[22px] font-bold <%= @available_balance_cents > 0 ? "text-sage-700" : "text-danger-700" %>">
            <%= number_to_currency(@available_balance_cents / 100.0, unit: "€", format: "%n %u") %>
          </div>
        </div>
        <div class="px-5 py-4">
          <%= link_to customers_wallet_reload_path, class: "inline-flex items-center gap-1.5 rounded-md border border-flour-400 bg-warm-white px-4 py-2 text-sm font-semibold text-ink-700 shadow-xs transition hover:bg-warm-white-2" do %>
            <%= lucide "wallet", size: 16, color: "var(--ink-700)" %> Recharger
          <% end %>
        </div>
      </div>
      <% if @available_balance_cents <= 0 %>
        <div class="border-t border-danger-200 bg-danger-100 px-5 py-2.5 text-sm text-danger-700">
          Solde insuffisant pour commander.
          <%= link_to "Recharger mon portefeuille", customers_wallet_reload_path, class: "font-semibold underline underline-offset-2" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @bake_days.empty? %>
    <div class="rounded-lg border border-flour-300 bg-warm-white p-8 text-center shadow-xs">
      <p class="text-ink-500">Aucune date de cuisson disponible pour le moment.</p>
    </div>
  <% else %>
    <!-- Calendrier Desktop -->
    <div class="hidden gap-6 lg:flex">
      <!-- Grille calendrier -->
      <div class="flex-1 rounded-lg border border-flour-300 bg-warm-white p-6 shadow-sm">
        <h2 class="mb-4 font-script text-2xl font-bold text-ink-900">Prochaines dates de cuisson</h2>

        <div class="space-y-2.5">
          <% last_month = nil %>
          <% @bake_days.each do |bake_day| %>
            <% this_month = I18n.with_locale(:fr) { I18n.l(bake_day.baked_on, format: "%B %Y") } %>
            <% if this_month != last_month %>
              <div class="px-0.5 pb-0.5 pt-2 text-xs font-semibold uppercase tracking-[0.08em] text-ink-400 first:pt-0"><%= this_month %></div>
              <% last_month = this_month %>
            <% end %>
            <% order = @planned_orders[bake_day.id] %>
            <% cut_off_passed = bake_day.cut_off_passed? %>
            <% can_order = !cut_off_passed %>

            <div class="flex items-center justify-between gap-3 rounded-lg border p-3.5 transition-all <%= cut_off_passed ? "border-warning-200 bg-warning-100" : "border-flour-300 bg-warm-white hover:border-sage-300" %>"
                 data-bake-day-id="<%= bake_day.id %>"
                 data-can-order="<%= can_order %>"
                 data-bake-date="<%= l(bake_day.baked_on, format: '%A %d/%m').downcase %>"
                 <% if order %>
                 data-order-items="<%= order.order_items.map { |i| { product_variant_id: i.product_variant_id, qty: i.qty } }.to_json %>"
                 <% end %>
                 <% if can_order %>
                 data-action="dragover->calendar#dragOver dragleave->calendar#dragLeave drop->calendar#drop"
                 <% end %>>
              <div class="flex items-center gap-3.5">
                <div class="flex h-12 w-12 flex-shrink-0 flex-col items-center justify-center rounded-md <%= cut_off_passed ? "bg-warning-200 text-warning-700" : "bg-sage-100 text-sage-700" %> leading-none">
                  <span class="text-lg font-bold"><%= bake_day.baked_on.day %></span>
                  <span class="mt-0.5 text-[9px] font-medium uppercase tracking-wide"><%= l(bake_day.baked_on, format: "%b").delete(".") %></span>
                </div>
                <div>
                  <p class="font-semibold text-ink-900">
                    <%= l(bake_day.baked_on, format: :long_with_day).capitalize %>
                  </p>
                  <% if cut_off_passed %>
                    <p class="text-xs text-warning-700">Il n'est plus possible de commander pour ce jour de cuisson</p>
                  <% elsif order %>
                    <p class="text-[13px] text-ink-500"><%= order.order_items.sum(&:qty) %> article(s) planifié(s) · <%= number_to_currency(order.total_cents / 100.0, unit: "€", format: "%n %u") %></p>
                  <% else %>
                    <p class="text-[13px] text-ink-500">Aucun produit pour l'instant</p>
                  <% end %>
                </div>
              </div>

              <% if order %>
                <div class="flex items-center gap-3">
                  <div class="text-right">
                    <p class="text-sm text-ink-500"><%= order.order_items.sum(&:qty) %> article(s)</p>
                    <p class="font-semibold text-sage-700"><%= number_to_currency(order.total_cents / 100.0, unit: "€", format: "%n %u") %></p>
                  </div>
                  <% if can_order %>
                    <button type="button"
                            class="rounded-md border border-flour-400 bg-warm-white px-3 py-1.5 text-sm font-semibold text-ink-700 transition hover:bg-flour-100"
                            data-action="calendar#openDayModal"
                            data-bake-day-id="<%= bake_day.id %>">
                      Modifier
                    </button>
                  <% end %>
                </div>
              <% elsif can_order %>
                <button type="button"
                        class="inline-flex items-center gap-1.5 rounded-md bg-sage-600 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-sage-500"
                        data-action="calendar#openDayModal"
                        data-bake-day-id="<%= bake_day.id %>">
                  <%= lucide "plus", size: 15, color: "#fff" %> Ajouter
                </button>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Sidebar produits (draggable) -->
      <div class="max-h-[calc(100vh-12rem)] w-80 overflow-y-auto rounded-lg border border-flour-300 bg-warm-white p-6 shadow-sm">
        <h2 class="mb-2 font-script text-2xl font-bold text-ink-900">Produits disponibles</h2>
        <div class="mb-4 flex items-center gap-2 rounded-md border border-sage-200 bg-sage-100 px-3 py-2 text-[12.5px] text-sage-700">
          <%= lucide "info", size: 15, color: "var(--sage-700)" %>
          <span>Glisse un produit sur une date, ou clique sur « Ajouter ».</span>
        </div>

        <% @product_variants.group_by { |v| v.product.category }.each do |category, category_variants| %>
          <h3 class="mb-2 mt-4 font-sans text-xs font-semibold uppercase tracking-wide text-ink-400 first:mt-0"><%= product_category_heading(category) %></h3>

          <% category_variants.group_by(&:product).each do |product, variants| %>
            <div class="mb-3">
              <div class="mb-1.5 flex items-center gap-2">
                <% first_image = product.product_images.first&.image %>
                <% if first_image&.attached? %>
                  <%= image_tag first_image.variant(resize_to_limit: [ 32, 32 ]), class: "h-8 w-8 rounded-sm object-cover" %>
                <% end %>
                <p class="text-sm font-semibold text-ink-900"><%= product.name %></p>
              </div>

              <div class="space-y-1.5">
                <% variants.each do |variant| %>
                  <div class="group/vrow flex cursor-grab items-center gap-2 rounded-md border border-flour-300 bg-warm-white px-2.5 py-2 transition-all hover:border-sage-300 hover:bg-flour-100 active:cursor-grabbing"
                       draggable="true"
                       data-variant-id="<%= variant.id %>"
                       data-price="<%= variant.price_cents %>"
                       data-product-name="<%= product.name %>"
                       data-variant-name="<%= variant.name %>"
                       data-product-category="<%= product_category_heading(category) %>"
                       data-action="dragstart->calendar#dragStart dragend->calendar#dragEnd">
                    <span class="text-ink-400"><%= lucide "chevron-right", size: 14, color: "var(--ink-400)" %></span>
                    <span class="flex-1 text-sm text-ink-700"><%= variant.name %></span>
                    <span class="text-sm font-semibold text-ink-900"><%= number_to_currency(variant.price_cents / 100.0, unit: "€", format: "%n %u") %></span>
                    <span class="inline-flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-sage-600 text-white transition group-hover/vrow:bg-ember-600"><%= lucide "plus", size: 14, color: "#fff" %></span>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Vue mobile (liste) -->
    <div class="space-y-4 lg:hidden">
      <% last_month_m = nil %>
      <% @bake_days.each do |bake_day| %>
        <% this_month_m = I18n.with_locale(:fr) { I18n.l(bake_day.baked_on, format: "%B %Y") } %>
        <% if this_month_m != last_month_m %>
          <div class="px-0.5 pt-1 text-xs font-semibold uppercase tracking-[0.08em] text-ink-400 first:pt-0"><%= this_month_m %></div>
          <% last_month_m = this_month_m %>
        <% end %>
        <% order = @planned_orders[bake_day.id] %>
        <% cut_off_passed = bake_day.cut_off_passed? %>
        <% can_order = !cut_off_passed %>

        <div class="rounded-lg border border-flour-300 bg-warm-white p-4 shadow-xs"
             data-bake-day-id="<%= bake_day.id %>"
             data-can-order="<%= can_order %>"
             data-bake-date="<%= l(bake_day.baked_on, format: '%A %d/%m').downcase %>"
             <% if order %>
             data-order-items="<%= order.order_items.map { |i| { product_variant_id: i.product_variant_id, qty: i.qty } }.to_json %>"
             <% end %>>
          <div class="flex items-start justify-between">
            <div class="flex items-center gap-3">
              <div class="flex h-11 w-11 flex-shrink-0 flex-col items-center justify-center rounded-md <%= cut_off_passed ? "bg-warning-200 text-warning-700" : "bg-sage-100 text-sage-700" %> leading-none">
                <span class="text-base font-bold"><%= bake_day.baked_on.day %></span>
                <span class="mt-0.5 text-[9px] font-medium uppercase"><%= l(bake_day.baked_on, format: "%b").delete(".") %></span>
              </div>
              <div>
                <p class="font-semibold text-ink-900">
                  <%= l(bake_day.baked_on, format: :long_with_day).capitalize %>
                </p>
                <% if cut_off_passed %>
                  <p class="mt-1 text-xs text-warning-700">Il n'est plus possible de commander pour ce jour de cuisson</p>
                <% end %>
              </div>
            </div>

            <% if can_order %>
              <button type="button"
                      class="rounded-md bg-sage-600 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-sage-500"
                      data-action="calendar#openDayModal"
                      data-bake-day-id="<%= bake_day.id %>">
                <%= order ? "Modifier" : "Commander" %>
              </button>
            <% end %>
          </div>

          <% if order %>
            <div class="mt-3 border-t border-flour-200 pt-3">
              <% order.order_items.each do |item| %>
                <div class="flex justify-between text-sm text-ink-700">
                  <span><%= item.product_variant.product.name %> (<%= item.qty %>)</span>
                  <span class="text-ink-500"><%= number_to_currency(item.qty * item.unit_price_cents / 100.0, unit: "€", format: "%n %u") %></span>
                </div>
              <% end %>
              <div class="mt-2 flex justify-between border-t border-flour-200 pt-2 font-semibold">
                <span class="text-ink-900">Total</span>
                <span class="text-sage-700"><%= number_to_currency(order.total_cents / 100.0, unit: "€", format: "%n %u") %></span>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Modal pour ajouter/modifier une commande -->
  <div data-calendar-target="modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
    <div class="flex min-h-screen items-center justify-center px-4">
      <!-- Overlay -->
      <div class="fixed inset-0 bg-ink-900/50" data-action="click->calendar#closeModal"></div>

      <!-- Modal content -->
      <div class="relative max-h-[90vh] w-full max-w-md overflow-hidden rounded-lg border border-flour-300 bg-warm-white shadow-lg">
        <!-- État formulaire -->
        <div data-calendar-target="modalForm">
          <div class="p-6">
            <div class="mb-4 flex items-center justify-between">
              <h3 class="font-script text-2xl font-bold text-ink-900" data-calendar-target="modalTitle">Planifier ma commande</h3>
              <button type="button" class="text-ink-400 transition hover:text-ink-700" data-action="click->calendar#closeModal">
                <%= lucide "x", size: 22, color: "currentColor" %>
              </button>
            </div>

            <!-- Product list -->
            <div class="max-h-[50vh] space-y-3 overflow-y-auto" data-calendar-target="productList">
              <!-- Products will be rendered here by Stimulus -->
            </div>

            <!-- Total -->
            <div class="mt-4 flex items-center justify-between border-t border-flour-300 pt-4">
              <span class="font-semibold text-ink-900">Total :</span>
              <span class="text-xl font-bold text-sage-700" data-calendar-target="modalTotal">0,00 €</span>
            </div>

            <!-- Balance indicator -->
            <div data-calendar-target="balanceIndicator" class="mt-2 text-sm"></div>
          </div>

          <!-- Actions -->
          <div class="flex justify-between bg-flour-100 px-6 py-4">
            <button type="button"
                    class="px-4 py-2 font-semibold text-danger-600 transition hover:text-danger-700"
                    data-action="click->calendar#deleteOrder">
              Vider
            </button>
            <div class="flex gap-2">
              <button type="button"
                      class="rounded-md border border-flour-400 bg-warm-white px-4 py-2 font-semibold text-ink-700 transition hover:bg-flour-100"
                      data-action="click->calendar#closeModal">
                Annuler
              </button>
              <button type="button"
                      class="rounded-md bg-sage-600 px-4 py-2 font-semibold text-white transition hover:bg-sage-500 disabled:cursor-not-allowed disabled:bg-flour-400"
                      data-action="click->calendar#saveOrder"
                      data-calendar-target="saveBtn">
                Enregistrer
              </button>
            </div>
          </div>
        </div>

        <!-- État confirmation (injecté par JS) -->
        <div data-calendar-target="modalSuccess" class="hidden p-6"></div>
      </div>
    </div>
  </div>

  <!-- Modale d'aide / onboarding -->
  <div data-calendar-intro-target="modal"
       data-calendar-intro-cta-url="<%= customers_wallet_reload_path %>"
       data-action="click->calendar-intro#overlayClick"
       class="hidden fixed inset-0 z-50 flex items-center justify-center overflow-y-auto bg-flour-50/50 px-4 backdrop-blur-md">
    <div class="relative max-h-[90vh] w-full max-w-lg overflow-hidden rounded-lg border border-flour-300 bg-warm-white shadow-lg">
      <!-- Barre du haut -->
      <div class="flex items-center justify-between px-6 pt-5">
        <button type="button"
                class="text-sm text-ink-500 underline underline-offset-2 transition hover:text-ink-700"
                data-action="click->calendar-intro#skip">
          Passer
        </button>
        <button type="button"
                class="text-ink-400 transition hover:text-ink-700"
                data-action="click->calendar-intro#close"
                aria-label="Fermer">
          <%= lucide "x", size: 22, color: "currentColor" %>
        </button>
      </div>

      <!-- Contenu des slides -->
      <div class="px-6 py-4">
        <!-- Slide 1 -->
        <div data-calendar-intro-target="slide" class="text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-sage-100 text-sage-600">
            <%= lucide "wallet", size: 30, color: "var(--sage-600)" %>
          </div>
          <h3 class="mb-3 font-script text-3xl font-bold text-ink-900">Commande ton pain à l'avance, en toute simplicité.</h3>
          <p class="leading-relaxed text-ink-700">
            Recharge ton portefeuille du montant de ton choix, puis utilise ce crédit pour réserver ton pain pour les prochaines dates de cuisson. Un peu comme un abonnement flexible, sans engagement.
          </p>
        </div>

        <!-- Slide 2 -->
        <div data-calendar-intro-target="slide" class="hidden text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-sage-100 text-sage-600">
            <%= lucide "info", size: 30, color: "var(--sage-600)" %>
          </div>
          <h3 class="mb-3 font-script text-3xl font-bold text-ink-900">Change d'avis quand tu veux.</h3>
          <p class="leading-relaxed text-ink-700">
            Tu peux ajouter, modifier ou supprimer ta commande jusqu'à la veille de la cuisson à l'heure de clôture des commandes. Même produit chaque semaine, ou quelque chose de différent à chaque fois — tu décides, date par date.
          </p>
        </div>

        <!-- Slide 3 -->
        <div data-calendar-intro-target="slide" class="hidden text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-sage-100 text-sage-600">
            <%= lucide "check", size: 30, color: "var(--sage-600)" %>
          </div>
          <h3 class="mb-3 font-script text-3xl font-bold text-ink-900">Ta commande se confirme toute seule.</h3>
          <p class="leading-relaxed text-ink-700">
            La veille de la cuisson, ta commande est automatiquement confirmée et le montant débité de ton portefeuille. Si ton solde est insuffisant, on te prévient par SMS et la commande est simplement annulée — aucun frais.
          </p>
        </div>

        <!-- Slide 4 (CTA) -->
        <div data-calendar-intro-target="slide" class="hidden text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-ember-100 text-ember-600">
            <%= lucide "flame", size: 30, color: "var(--ember-600)" %>
          </div>
          <h3 class="mb-3 font-script text-3xl font-bold text-ink-900">Prêt·e à essayer ?</h3>
          <div class="mt-4 flex flex-col gap-2">
            <button type="button"
                    class="w-full rounded-md bg-ember-600 px-4 py-3 font-semibold text-white transition hover:bg-ember-500"
                    data-action="click->calendar-intro#goToCta">
              Recharger mon portefeuille
            </button>
            <button type="button"
                    class="w-full rounded-md border border-flour-400 bg-warm-white px-4 py-3 font-semibold text-ink-700 transition hover:bg-flour-100"
                    data-action="click->calendar-intro#close">
              Explorer d'abord
            </button>
          </div>
          <p class="mt-4 text-xs text-ink-500">
            Une question ? Tu peux rouvrir cette aide à tout moment via le bouton « Comment ça marche ? ».
          </p>
        </div>
      </div>

      <!-- Navigation (slides 1-3) -->
      <div data-calendar-intro-target="navBar" class="flex items-center justify-between bg-flour-100 px-6 py-4">
        <button type="button"
                class="px-4 py-2 text-sm text-ink-500 transition hover:text-ink-700 disabled:cursor-not-allowed disabled:opacity-40"
                data-calendar-intro-target="prevBtn"
                data-action="click->calendar-intro#prev">
          Précédent
        </button>

        <!-- Indicateur de progression -->
        <div class="flex gap-1.5">
          <span data-calendar-intro-target="progressDot" class="h-2 w-2 rounded-full bg-sage-600 transition-colors"></span>
          <span data-calendar-intro-target="progressDot" class="h-2 w-2 rounded-full bg-flour-400 transition-colors"></span>
          <span data-calendar-intro-target="progressDot" class="h-2 w-2 rounded-full bg-flour-400 transition-colors"></span>
          <span data-calendar-intro-target="progressDot" class="h-2 w-2 rounded-full bg-flour-400 transition-colors"></span>
        </div>

        <button type="button"
                class="rounded-md bg-sage-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sage-500"
                data-calendar-intro-target="nextBtn"
                data-action="click->calendar-intro#next">
          Suivant
        </button>
      </div>
    </div>
  </div>
</div>
