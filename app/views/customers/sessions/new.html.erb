<% content_for :title, "Connexion" %>

<div class="mx-auto w-full max-w-md">
  <h1 class="mb-6 font-script text-4xl font-bold text-ink-900 sm:text-5xl">Connexion</h1>

  <div class="mb-6 flex gap-3 rounded-md border border-sage-200 bg-sage-100 p-4">
    <span class="mt-0.5 flex-shrink-0 text-sage-700"><%= lucide "info", size: 18, color: "var(--sage-700)" %></span>
    <p class="text-sm leading-relaxed text-ink-700">
      Connecte-toi avec ton <strong class="font-semibold text-ink-900">numéro de GSM</strong> ou ton <strong class="font-semibold text-ink-900">adresse e-mail</strong>, comme tu préfères&nbsp;:
      on t'envoie un code de connexion par SMS ou par e-mail selon ce que tu saisis.
    </p>
  </div>

  <div class="rounded-lg border border-flour-300 bg-warm-white p-6 shadow-sm">
    <%= form_with url: customer_login_path, local: true, data: { controller: "customer-session" } do |f| %>
      <%# Étapes 1 & 2 : identifiant puis code de vérification %>
      <div id="credentials-step" class="<%= "hidden" if @needs_name %>">
        <div class="mb-2" data-controller="phone-input" data-phone-input-default-country-value="BE">
          <%= f.label :identifier, "Ton numéro de GSM ou ton e-mail", class: "mb-2 block text-[15px] font-medium text-ink-700" %>
          <div class="relative">
            <%= f.text_field :identifier,
                value: @identifier,
                data: {
                  customer_session_target: "identifierInput",
                  phone_input_target: "input",
                  action: "input->customer-session#updateChannelHint"
                },
                class: "h-12 w-full rounded-md border border-flour-400 bg-white pl-3 pr-24 text-[15px] text-ink-900 shadow-[inset_0_1px_2px_rgba(74,60,38,0.06)] focus:border-sage-600 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]",
                required: true,
                autocomplete: "username",
                placeholder: "+32 4XX XX XX XX ou prenom@exemple.be" %>
            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
              <span data-phone-input-target="flag" class="text-xl">🇧🇪</span>
            </div>
          </div>
        </div>

        <p id="channel-hint" data-customer-session-target="channelHint" class="mb-4 h-5 text-sm text-ink-500"></p>

        <button type="button"
                id="send-otp-btn"
                data-action="click->customer-session#sendCode"
                class="flex h-11 w-full items-center justify-center rounded-md bg-sage-600 px-4 text-sm font-semibold text-white shadow-xs transition hover:bg-sage-500 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]">
          Recevoir mon code
        </button>

        <div id="otp-input-section" class="hidden mt-4">
          <div class="mb-4">
            <%= label_tag :otp_code, "Code de vérification (6 chiffres)", class: "mb-2 block text-[13px] font-medium text-ink-700" %>
            <%= text_field_tag :otp_code, nil,
                id: "otp_code",
                maxlength: 6,
                inputmode: "numeric",
                pattern: "\\d{6}",
                autocomplete: "one-time-code",
                data: { customer_session_target: "otpInput" },
                class: "h-12 w-full rounded-md border border-flour-400 bg-white px-3 text-center text-lg tracking-[0.3em] text-ink-900 shadow-[inset_0_1px_2px_rgba(74,60,38,0.06)] focus:border-sage-600 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]",
                placeholder: "123456" %>
          </div>

          <button type="button"
                  id="verify-otp-btn"
                  data-action="click->customer-session#verifyOTP"
                  class="flex h-11 w-full items-center justify-center rounded-md bg-sage-600 px-4 text-sm font-semibold text-white shadow-xs transition hover:bg-sage-500">
            Vérifier le code
          </button>

          <div class="mt-4 text-center">
            <button type="button"
                    id="resend-otp-btn"
                    data-action="click->customer-session#sendCode"
                    class="text-sm font-medium text-ember-600 underline underline-offset-2 hover:text-ember-500">
              Renvoyer le code
            </button>
          </div>
        </div>

        <div id="otp-message" class="mt-4 hidden"></div>
      </div>

      <%# Étape 3 : prénom — uniquement pour un identifiant inconnu (création de compte) %>
      <div id="name-step" class="<%= "hidden" unless @needs_name %>">
        <p class="mb-4 text-sm text-ink-700">Bienvenue&nbsp;! Il nous manque juste ton prénom pour créer ton compte.</p>

        <div class="mb-4">
          <%= label_tag :signup_first_name, "Ton prénom", class: "mb-2 block text-[13px] font-medium text-ink-700" %>
          <%= text_field_tag :first_name, nil,
              id: "signup_first_name",
              data: { customer_session_target: "firstNameInput" },
              class: "h-12 w-full rounded-md border border-flour-400 bg-white px-3 text-[15px] text-ink-900 shadow-[inset_0_1px_2px_rgba(74,60,38,0.06)] focus:border-sage-600 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]",
              required: true %>
        </div>

        <div class="mb-4">
          <%= label_tag :signup_last_name, "Ton nom (optionnel)", class: "mb-2 block text-[13px] font-medium text-ink-700" %>
          <%= text_field_tag :last_name, nil,
              id: "signup_last_name",
              data: { customer_session_target: "lastNameInput" },
              class: "h-12 w-full rounded-md border border-flour-400 bg-white px-3 text-[15px] text-ink-900 shadow-[inset_0_1px_2px_rgba(74,60,38,0.06)] focus:border-sage-600 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]" %>
        </div>

        <button type="button"
                id="complete-signup-btn"
                data-action="click->customer-session#completeSignup"
                class="flex h-11 w-full items-center justify-center rounded-md bg-sage-600 px-4 text-sm font-semibold text-white shadow-xs transition hover:bg-sage-500 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]">
          Créer mon compte
        </button>

        <div id="name-message" class="mt-4 hidden"></div>
      </div>

      <%# Marqueur lu par le JS pour révéler l'étape prénom après validation du code %>
      <% if @needs_name %><div id="needs-name-marker" hidden></div><% end %>
    <% end %>
  </div>
</div>
