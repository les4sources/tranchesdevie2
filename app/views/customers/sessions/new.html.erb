<% content_for :title, "Connexion" %>

<div class="w-full mx-auto max-w-md">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Connexion</h1>

  <div class="mb-6 rounded-lg border border-blue-200 bg-blue-50 p-4">
    <div class="flex gap-3">
      <div class="flex-shrink-0">
        <span class="material-symbols-outlined text-blue-600">info</span>
      </div>
      <div>
        <p class="text-sm text-blue-900">
          Chaque mangeur.se est désormais identifié par un numéro de téléphone mobile, ce qui nous
          permet de te contacter en cas de besoin, et de t'envoyer un SMS lorsque tes commandes sont prêtes.
        </p>
        <p class="text-sm mt-2 font-bold text-blue-900">
          Si tu ne reçois pas le code tout de suite, tu peux envoyer ta commande par e-mail à <a href="mailto:boulangerie@les4sources.be" class="text-blue-600">boulangerie@les4sources.be</a>.
        </p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <%= form_with url: customer_login_path, local: true, data: { controller: "customer-session" } do |f| %>
      <div id="phone-verification-step">
        <div class="mb-4" data-controller="phone-input" data-phone-input-default-country-value="BE">
          <%= f.label :phone_e164, "Ton numéro de GSM", class: "block text-md font-medium text-gray-700 mb-2" %>
          <div class="relative">
            <%= f.text_field :phone_e164, 
                value: @phone_e164,
                data: { 
                  customer_session_target: "phoneInput",
                  phone_input_target: "input"
                },
                class: "w-full rounded-md border-1 border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2 text-lg pr-24",
                required: true,
                pattern: "\\+[1-9]\\d{1,14}",
                autocomplete: "tel" %>
            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
              <span 
                data-phone-input-target="flag"
                class="text-xl">
                🇧🇪
              </span>
            </div>
          </div>
        </div>

        <p class="mb-4 rounded-md border border-gray-200 bg-gray-50 px-3 py-2.5 text-xs leading-relaxed text-gray-600">
          En continuant, tu acceptes de recevoir des SMS transactionnels (code de connexion, confirmations, notification "pain prêt"). Fréquence&nbsp;: 1 à 3 SMS par commande. Pas de SMS marketing.
          Désinscription à tout moment depuis ton compte. Voir nos <%= link_to "conditions SMS", sms_terms_path, class: "text-blue-600 hover:underline", target: "_blank", rel: "noopener" %> et notre <%= link_to "politique de confidentialité", privacy_policy_path, class: "text-blue-600 hover:underline", target: "_blank", rel: "noopener" %>.
        </p>

        <button type="button"
                id="send-otp-btn"
                data-action="click->customer-session#sendOTP"
                class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
          Me connecter
        </button>

        <div id="otp-input-section" class="hidden mt-4">
          <div class="mb-4">
            <%= label_tag :otp_code, "Code de vérification (6 chiffres)", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= text_field_tag :otp_code, nil, 
                id: "otp_code",
                maxlength: 6,
                pattern: "\\d{6}",
                data: { customer_session_target: "otpInput" },
                class: "w-full rounded-md border-gray-300 shadow-sm p-2 text-lg focus:border-blue-500 focus:ring-blue-500",
                placeholder: "123456" %>
          </div>

          <button type="button" 
                  id="verify-otp-btn" 
                  data-action="click->customer-session#verifyOTP"
                  class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700">
            Vérifier le code
          </button>
        </div>

        <div id="otp-message" class="mt-4 hidden"></div>
      </div>
    <% end %>
  </div>
</div>

