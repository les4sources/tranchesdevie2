<% content_for :title, "Connexion" %>

<div class="w-full mx-auto max-w-md">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Connexion</h1>

  <div class="mb-6 rounded-lg border border-blue-200 bg-blue-50 p-4">
    <div class="flex gap-3">
      <div class="flex-shrink-0">
        <span class="material-symbols-outlined text-blue-600">info</span>
      </div>
      <div>
        <p class="text-sm text-blue-900">
          Connecte-toi avec ton <strong>numéro de GSM</strong> ou ton <strong>adresse e-mail</strong>, comme tu préfères&nbsp;:
          on t'envoie un code de connexion par SMS ou par e-mail selon ce que tu saisis.
        </p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <%= form_with url: customer_login_path, local: true, data: { controller: "customer-session" } do |f| %>
      <%# Étapes 1 & 2 : identifiant puis code de vérification %>
      <div id="credentials-step" class="<%= "hidden" if @needs_name %>">
        <div class="mb-2" data-controller="phone-input" data-phone-input-default-country-value="BE">
          <%= f.label :identifier, "Ton numéro de GSM ou ton e-mail", class: "block text-md font-medium text-gray-700 mb-2" %>
          <div class="relative">
            <%= f.text_field :identifier,
                value: @identifier,
                data: {
                  customer_session_target: "identifierInput",
                  phone_input_target: "input",
                  action: "input->customer-session#updateChannelHint"
                },
                class: "w-full rounded-md border-1 border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2 text-lg pr-24",
                required: true,
                autocomplete: "username",
                placeholder: "+32 4XX XX XX XX ou prenom@exemple.be" %>
            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
              <span data-phone-input-target="flag" class="text-xl">🇧🇪</span>
            </div>
          </div>
        </div>

        <p id="channel-hint" data-customer-session-target="channelHint" class="mb-4 text-sm text-gray-500 h-5"></p>

        <button type="button"
                id="send-otp-btn"
                data-action="click->customer-session#sendCode"
                class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
          Recevoir mon code
        </button>

        <div id="otp-input-section" class="hidden mt-4">
          <div class="mb-4">
            <%= label_tag :otp_code, "Code de vérification (6 chiffres)", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= text_field_tag :otp_code, nil,
                id: "otp_code",
                maxlength: 6,
                inputmode: "numeric",
                pattern: "\\d{6}",
                autocomplete: "one-time-code",
                data: { customer_session_target: "otpInput" },
                class: "w-full rounded-md border-gray-300 shadow-sm p-2 text-lg tracking-[0.3em] text-center focus:border-blue-500 focus:ring-blue-500",
                placeholder: "123456" %>
          </div>

          <button type="button"
                  id="verify-otp-btn"
                  data-action="click->customer-session#verifyOTP"
                  class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700">
            Vérifier le code
          </button>

          <div class="mt-4 text-center">
            <button type="button"
                    id="resend-otp-btn"
                    data-action="click->customer-session#sendCode"
                    class="text-sm font-medium text-blue-600 hover:text-blue-800 underline">
              Renvoyer le code
            </button>
          </div>
        </div>

        <div id="otp-message" class="mt-4 hidden"></div>
      </div>

      <%# Étape 3 : prénom — uniquement pour un identifiant inconnu (création de compte) %>
      <div id="name-step" class="<%= "hidden" unless @needs_name %>">
        <p class="mb-4 text-sm text-gray-700">Bienvenue&nbsp;! Il nous manque juste ton prénom pour créer ton compte.</p>

        <div class="mb-4">
          <%= label_tag :signup_first_name, "Ton prénom", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= text_field_tag :first_name, nil,
              id: "signup_first_name",
              data: { customer_session_target: "firstNameInput" },
              class: "w-full rounded-md border-1 border-gray-300 shadow-sm p-2 text-lg focus:border-blue-500 focus:ring-blue-500",
              required: true %>
        </div>

        <div class="mb-4">
          <%= label_tag :signup_last_name, "Ton nom (optionnel)", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= text_field_tag :last_name, nil,
              id: "signup_last_name",
              data: { customer_session_target: "lastNameInput" },
              class: "w-full rounded-md border-1 border-gray-300 shadow-sm p-2 text-lg focus:border-blue-500 focus:ring-blue-500" %>
        </div>

        <button type="button"
                id="complete-signup-btn"
                data-action="click->customer-session#completeSignup"
                class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
          Créer mon compte
        </button>

        <div id="name-message" class="mt-4 hidden"></div>
      </div>

      <%# Marqueur lu par le JS pour révéler l'étape prénom après validation du code %>
      <% if @needs_name %><div id="needs-name-marker" hidden></div><% end %>
    <% end %>
  </div>
</div>
