<% content_for :title, "Recharger mon portefeuille" %>

<div class="mx-auto w-full max-w-md">
  <div class="mb-6">
    <%= link_to customers_wallet_path, class: "inline-flex items-center gap-1.5 text-sm font-semibold text-ember-600 hover:text-ember-500" do %>
      <%= lucide "arrow-left", size: 16, color: "var(--ember-600)" %> Retour
    <% end %>
  </div>

  <div class="overflow-hidden rounded-lg border border-flour-300 bg-warm-white shadow-sm">
    <div class="p-6">
      <h1 class="mb-5 font-script text-3xl font-bold text-ink-900">Recharger mon portefeuille</h1>

      <div class="mb-6">
        <p class="text-sm text-ink-500">Solde actuel</p>
        <p class="text-2xl font-bold <%= @wallet.balance_cents >= 0 ? "text-sage-700" : "text-danger-700" %>">
          <%= number_to_currency(@wallet.balance_euros, unit: "€", format: "%n %u") %>
        </p>
      </div>

      <div data-controller="wallet-reload" data-wallet-reload-create-url-value="<%= customers_wallet_create_reload_path %>">
        <!-- Info pédagogique -->
        <div class="mb-6 flex gap-3 rounded-md border border-sage-200 bg-sage-100 p-4">
          <span class="mt-0.5 flex-shrink-0 text-sage-700"><%= lucide "info", size: 18, color: "var(--sage-700)" %></span>
          <div class="text-sm leading-relaxed text-ink-700">
            <p class="mb-1 font-semibold text-ink-900">À quoi sert ce crédit&nbsp;?</p>
            <p>
              Il te permet de réserver ton pain pour les prochaines dates de cuisson sur ton
              <%= link_to "calendrier", calendar_path, class: "font-semibold text-sage-700 underline underline-offset-2 hover:text-sage-600" %>.
              Tu peux modifier tes commandes jusqu'à la veille, et demander un remboursement à tout moment en nous contactant.
            </p>
          </div>
        </div>

        <!-- Montant -->
        <div class="mb-6">
          <label class="mb-2 block text-[13px] font-medium text-ink-700">Montant à recharger</label>
          <div class="mb-3 grid grid-cols-4 gap-2">
            <% [ [ "1000", "10€" ], [ "2000", "20€" ], [ "5000", "50€" ], [ "10000", "100€" ] ].each do |cents, label| %>
              <button type="button" data-wallet-reload-target="amountBtn" data-amount="<%= cents %>"
                      class="rounded-md border border-flour-400 bg-warm-white px-3 py-2.5 text-sm font-bold text-ink-900 transition hover:border-sage-500 hover:bg-flour-100 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]">
                <%= label %>
              </button>
            <% end %>
          </div>
          <div class="relative">
            <input type="number" min="5" step="1" placeholder="Autre montant"
                   data-wallet-reload-target="customAmount"
                   class="h-11 w-full rounded-md border border-flour-400 bg-white px-4 text-[15px] text-ink-900 shadow-[inset_0_1px_2px_rgba(74,60,38,0.06)] focus:border-sage-600 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]">
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-ink-500">€</span>
          </div>
        </div>

        <!-- Montant sélectionné -->
        <div class="mb-6 rounded-md bg-flour-100 p-4">
          <p class="text-sm text-ink-500">Montant de la recharge</p>
          <p class="text-2xl font-bold text-ink-900" data-wallet-reload-target="selectedAmount">0 €</p>
        </div>

        <!-- Erreurs -->
        <p data-wallet-reload-target="error" class="mb-4 hidden text-sm text-danger-700"></p>

        <!-- Submit -->
        <button type="button" data-action="click->wallet-reload#submit"
                data-wallet-reload-target="submitBtn"
                class="flex h-12 w-full items-center justify-center rounded-md bg-ember-600 px-4 font-semibold text-white shadow-xs transition hover:bg-ember-500 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)] disabled:cursor-not-allowed disabled:bg-flour-400">
          <span data-wallet-reload-target="btnText">Payer avec Bancontact</span>
          <span data-wallet-reload-target="btnSpinner" class="hidden">
            Traitement en cours...
          </span>
        </button>
      </div>
    </div>
  </div>
</div>
