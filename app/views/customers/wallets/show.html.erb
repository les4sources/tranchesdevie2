<% content_for :title, "Mon portefeuille" %>

<div class="w-full">
  <div class="mb-7 flex flex-wrap items-end justify-between gap-3">
    <div>
      <div class="tdv-eyebrow mb-1.5 text-sage-700">Ta cagnotte à pain</div>
      <h1 class="font-script text-4xl font-bold text-ink-900 sm:text-5xl">Mon portefeuille</h1>
    </div>
    <div class="flex items-center gap-2.5">
      <%= link_to "Mon calendrier", calendar_path, class: "rounded-md border border-flour-400 bg-warm-white px-4 py-2 text-sm font-semibold text-ink-700 shadow-xs transition hover:bg-warm-white-2" %>
      <%= link_to customers_wallet_reload_path, class: "inline-flex items-center gap-1.5 rounded-md bg-sage-600 px-4 py-2 text-sm font-semibold text-white shadow-xs transition hover:bg-sage-500" do %>
        <%= lucide "plus", size: 16, color: "#fff" %> Recharger
      <% end %>
    </div>
  </div>

  <!-- Carte solde + recharge (ticket) -->
  <div data-controller="wallet-reload" data-wallet-reload-create-url-value="<%= customers_wallet_create_reload_path %>"
       class="relative mb-7 grid overflow-hidden rounded-xl border border-sage-200 bg-gradient-to-br from-sage-100 via-flour-50 to-flour-50 shadow-md md:grid-cols-[1.05fr_1fr]">
    <div class="pointer-events-none absolute -right-7 -top-7 rotate-12 opacity-30"><%= lucide "wheat", size: 200, color: "var(--sage-300)" %></div>

    <!-- Solde -->
    <div class="relative p-8 sm:p-10">
      <div class="mb-3 text-xs font-semibold uppercase tracking-[0.08em] text-sage-700">Solde disponible</div>
      <div class="text-5xl font-bold leading-none tracking-tight text-ink-900 sm:text-6xl">
        <%= number_to_currency(@wallet.balance_euros, unit: "€", format: "%n %u") %>
      </div>
      <% if @wallet.low_balance? %>
        <div class="mt-5 inline-flex items-center gap-2 rounded-full border border-ember-200 bg-ember-100 px-3 py-1.5 text-[13px] font-semibold text-ember-700">
          <%= lucide "alert-triangle", size: 14, color: "var(--ember-600)" %> Solde bas — pense à recharger
        </div>
      <% end %>
    </div>

    <!-- Séparateur ticket -->
    <div class="pointer-events-none absolute bottom-0 left-[calc(52.5%-1px)] top-0 hidden border-l-2 border-dashed border-sage-300 md:block"></div>
    <div class="pointer-events-none absolute -top-[11px] left-[52.5%] -ml-[11px] hidden h-[22px] w-[22px] rounded-full bg-flour-100 md:block"></div>
    <div class="pointer-events-none absolute -bottom-[11px] left-[52.5%] -ml-[11px] hidden h-[22px] w-[22px] rounded-full bg-flour-100 md:block"></div>

    <!-- Recharge -->
    <div class="relative bg-warm-white/55 p-7 sm:p-8">
      <div class="mb-3.5 text-[15px] font-semibold text-ink-900">Recharger mon portefeuille</div>
      <div class="mb-3.5 grid grid-cols-2 gap-2.5">
        <% [ [ "2000", "20 €" ], [ "4000", "40 €", true ], [ "6000", "60 €" ], [ "10000", "100 €" ] ].each do |cents, label, default| %>
          <button type="button" data-wallet-reload-target="amountBtn" data-amount="<%= cents %>" <%= "data-default" if default %>
                  class="flex items-center justify-center rounded-md border border-flour-400 bg-warm-white py-3 text-[17px] font-bold text-ink-900 transition hover:border-sage-500 hover:bg-flour-100 focus:outline-none">
            <%= label %>
          </button>
        <% end %>
      </div>
      <button type="button" data-action="click->wallet-reload#submit" data-wallet-reload-target="submitBtn"
              class="flex h-12 w-full items-center justify-center gap-2 rounded-md bg-sage-600 px-4 text-base font-semibold text-white shadow-xs transition hover:bg-sage-500 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)] disabled:cursor-not-allowed disabled:bg-flour-400">
        <span data-wallet-reload-target="btnText" class="inline-flex items-center gap-2"><%= lucide "credit-card", size: 18, color: "#fff" %> Recharger <span data-wallet-reload-target="selectedAmount">0 €</span></span>
        <span data-wallet-reload-target="btnSpinner" class="hidden">Traitement en cours…</span>
      </button>
      <p data-wallet-reload-target="error" class="mt-3 hidden text-sm text-danger-700"></p>
      <div class="mt-3 flex items-center justify-center gap-2 text-xs text-ink-500">
        <%= lucide "shield-check", size: 14, color: "var(--sage-600)" %> Paiement sécurisé par Bancontact
      </div>
    </div>
  </div>

  <!-- Mini-stats -->
  <div class="mb-7 grid grid-cols-1 gap-3.5 sm:grid-cols-3">
    <div class="flex flex-col gap-1 rounded-md border border-flour-300 bg-warm-white p-4">
      <span class="text-[13px] font-medium text-ink-500">Total rechargé</span>
      <span class="text-[28px] font-bold leading-none text-ink-900"><%= number_to_currency(@total_recharged_cents / 100.0, unit: "€", format: "%n %u") %></span>
      <span class="text-xs text-ink-500">depuis le début</span>
    </div>
    <div class="flex flex-col gap-1 rounded-md border border-flour-300 bg-warm-white p-4">
      <span class="text-[13px] font-medium text-ink-500">Total dépensé</span>
      <span class="text-[28px] font-bold leading-none text-ink-900"><%= number_to_currency(@total_spent_cents / 100.0, unit: "€", format: "%n %u") %></span>
      <span class="text-xs text-ink-500">en délicieux pains et compagnie</span>
    </div>
    <div class="flex flex-col gap-1 rounded-md border border-sage-200 bg-sage-100 p-4">
      <span class="text-[13px] font-medium text-ink-500">Commandes</span>
      <span class="text-[28px] font-bold leading-none text-ink-900"><%= @orders_count %></span>
      <span class="text-xs text-ink-500">passées via le portefeuille</span>
    </div>
  </div>

  <!-- Historique des transactions -->
  <div class="overflow-hidden rounded-lg border border-flour-300 bg-warm-white shadow-sm">
    <h2 class="px-6 pb-3 pt-4 font-script text-2xl font-bold text-ink-900">Entrées et sorties de ton portefeuille</h2>
    <div class="px-3 pb-3 pt-1 sm:px-4 sm:pb-4">
      <% if @transactions.any? %>
        <div class="flex flex-col">
          <% @transactions.each do |transaction| %>
            <% credit = transaction.amount_cents >= 0 %>
            <% tx_icon = { "top_up" => "wallet", "order_refund" => "arrow-left" }.fetch(transaction.transaction_type, "shopping-basket") %>
            <% tx_label = { "top_up" => "Recharge", "order_debit" => "Commande", "order_refund" => "Remboursement" }[transaction.transaction_type] %>
            <div class="flex items-center justify-between gap-4 rounded-md px-3 py-3 transition hover:bg-warm-white-2">
              <div class="flex items-center gap-3">
                <span class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full <%= credit ? "bg-sage-100 text-sage-700" : "bg-flour-200 text-ink-500" %>">
                  <%= lucide tx_icon, size: 16, color: "currentColor" %>
                </span>
                <div>
                  <p class="font-semibold text-ink-900"><%= tx_label %></p>
                  <p class="text-[13px] text-ink-500"><%= l(transaction.created_at, format: :long) %></p>
                  <% if transaction.description.present? %>
                    <p class="text-[13px] text-ink-400"><%= transaction.description %></p>
                  <% end %>
                </div>
              </div>
              <p class="font-semibold <%= credit ? "text-sage-700" : "text-ink-900" %>">
                <%= credit ? "+" : "" %><%= number_to_currency(transaction.amount_euros, unit: "€", format: "%n %u") %>
              </p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="py-8 text-center text-ink-500">Aucune transaction pour le moment</p>
      <% end %>
    </div>
  </div>
</div>
