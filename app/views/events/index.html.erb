<% content_for :title, "Événements — Pizza Party privée" %>

<section class="border-b border-flour-300 bg-gradient-to-b from-sage-100 to-flour-50">
  <div class="mx-auto max-w-[1040px] px-6 py-12 md:py-14">
    <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-sage-200 bg-warm-white px-3 py-1.5 text-xs font-semibold uppercase tracking-wide text-sage-700">
      <%= lucide "party-popper", size: 14, color: "var(--ember-600)" %> Événements
    </div>
    <h1 class="font-script text-[40px] font-bold leading-[0.95] text-ink-900 sm:text-5xl">Organise ta Pizza Party privée</h1>
    <p class="mt-4 max-w-xl text-[17px] leading-relaxed text-ink-700">
      On prépare les pâtons, tu t'occupes de la fête. Réserve le nombre de personnes ci-dessous —
      chacun repart avec sa boule de pâte à pizza, prête à garnir et enfourner.
    </p>
  </div>
</section>

<div class="mx-auto max-w-[1040px] px-6 py-10">
  <% if (@product && @selected_variant) || @public_variants %>
    <% if @product && @selected_variant %>
    <div class="grid gap-8 md:grid-cols-[1.1fr_0.9fr] md:items-start">
      <div>
        <h2 class="text-2xl font-semibold text-ink-900"><%= @product.name.split("–").first.strip %></h2>
        <p class="mt-3 text-base leading-relaxed text-ink-700"><%= @product.description %></p>
        <ul class="mt-6 space-y-2 text-sm text-ink-700">
          <li class="flex items-center gap-2">
            <%= lucide "check", size: 18, color: "var(--sage-700)" %> 1 boule de pâte à pizza par personne
          </li>
          <li class="flex items-center gap-2">
            <%= lucide "check", size: 18, color: "var(--sage-700)" %> Un forfait de 40 € est ajouté automatiquement à ta réservation
          </li>
          <li class="flex items-center gap-2">
            <%= lucide "check", size: 18, color: "var(--sage-700)" %> Récupération avec ta commande, sur le lieu choisi au paiement
          </li>
        </ul>
      </div>

      <div class="rounded-2xl border border-flour-300 bg-warm-white p-6 shadow-xs" data-controller="quantity-selector">
        <h3 class="text-lg font-semibold text-ink-900">Réserver</h3>
        <p class="mt-1 text-sm text-ink-500">
          <%= number_to_currency(@selected_variant.price_euros, unit: "€", separator: ",", delimiter: " ") %> / personne
          <span class="text-ink-400">·</span> forfait 40 €
        </p>

        <%= form_with url: cart_add_path, method: :post, local: true, data: { action: "submit->cart#add" }, class: "mt-5 flex flex-col gap-5" do |f| %>
          <%= f.hidden_field :product_variant_id, value: @selected_variant.id %>
          <%= f.hidden_field :qty, value: 1, data: { quantity_selector_target: "input" } %>

          <div>
            <span class="text-sm font-medium text-ink-900">Choisis ta date et ton créneau</span>
            <div class="mt-2 max-h-72 space-y-4 overflow-y-auto rounded-lg border border-flour-300 bg-flour-50 p-3">
              <% months = (@party_availability || {}).group_by { |date, _slots| date.beginning_of_month } %>
              <% any_open = false %>
              <% months.each do |month, days| %>
                <% open_days = days.select { |_date, slots| slots.values.any? } %>
                <% next if open_days.empty? %>
                <% any_open = true %>
                <div>
                  <p class="mb-1.5 text-xs font-semibold uppercase tracking-wide text-ink-500">
                    <%= I18n.with_locale(:fr) { I18n.l(month, format: "%B %Y") }.capitalize %>
                  </p>
                  <div class="grid grid-cols-2 gap-2 sm:grid-cols-3">
                    <% open_days.each do |date, slots| %>
                      <div class="rounded-md border border-flour-300 bg-warm-white p-2">
                        <p class="text-[13px] font-semibold text-ink-900">
                          <%= I18n.with_locale(:fr) { I18n.l(date, format: "%a %-d") }.capitalize %>
                        </p>
                        <div class="mt-1.5 flex gap-1.5">
                          <% PartyEvent::SLOT_LABELS.each do |slot, slot_label| %>
                            <% if slots[slot] %>
                              <label class="inline-flex cursor-pointer items-center rounded-full border border-flour-400 px-2.5 py-1 text-xs font-semibold text-ink-700 transition hover:border-sage-300 has-[:checked]:border-sage-600 has-[:checked]:bg-sage-600 has-[:checked]:text-white">
                                <input type="radio" name="party_slot_choice" value="<%= date.iso8601 %>|<%= slot %>" class="sr-only" required>
                                <%= slot_label %>
                              </label>
                            <% else %>
                              <span class="inline-flex items-center rounded-full border border-flour-300 bg-flour-200 px-2.5 py-1 text-xs font-semibold text-ink-400 line-through">
                                <%= slot_label %>
                              </span>
                            <% end %>
                          <% end %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
              <% unless any_open %>
                <p class="text-sm text-ink-600">Aucun créneau disponible pour le moment — recontacte-nous bientôt !</p>
              <% end %>
            </div>
          </div>

          <div>
            <span class="text-sm font-medium text-ink-900">Nombre de personnes</span>
            <div class="mt-2 flex items-center gap-2">
              <button type="button" data-action="click->quantity-selector#decrement" class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-flour-400 text-ink-700 transition hover:bg-flour-100">
                <%= lucide "minus", size: 16, color: "var(--ink-700)" %>
              </button>
              <span class="inline-flex h-10 min-w-12 items-center justify-center rounded-md bg-flour-100 text-sm font-semibold text-ink-900" data-quantity-selector-target="display">1</span>
              <button type="button" data-action="click->quantity-selector#increment" class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-flour-400 text-ink-700 transition hover:bg-flour-100">
                <%= lucide "plus", size: 16, color: "var(--ink-700)" %>
              </button>
            </div>
          </div>

          <button type="submit" class="flex w-full items-center justify-center gap-2 rounded-md bg-ember-600 px-6 py-3 text-base font-semibold text-white shadow-xs transition hover:bg-ember-500">
            <%= lucide "shopping-basket", size: 18, color: "#fff" %> Réserver ma Pizza Party
          </button>
          <p class="text-center text-xs text-ink-500">Le forfait de 40 € est ajouté automatiquement au panier.</p>
        <% end %>
      </div>
    </div>
    <% end %>

    <% if @public_variants %>
      <div class="<%= "mt-14 border-t border-flour-300 pt-10" if @product && @selected_variant %>">
        <div class="grid gap-8 md:grid-cols-[1.1fr_0.9fr] md:items-start">
          <div>
            <h2 class="text-2xl font-semibold text-ink-900"><%= @public_product.name %></h2>
            <% if @public_product.description.present? %>
              <p class="mt-3 text-base leading-relaxed text-ink-700"><%= @public_product.description %></p>
            <% end %>
            <p class="mt-4 text-sm text-ink-600">Ouvert à tous : choisis le nombre d'adultes et d'enfants, chacun repart avec son pâton.</p>
          </div>

          <div class="rounded-2xl border border-flour-300 bg-warm-white p-6 shadow-xs">
            <h3 class="text-lg font-semibold text-ink-900">Réserver</h3>
            <div class="mt-4 space-y-3">
              <% @public_variants.each do |variant| %>
                <div class="rounded-xl border border-flour-300 p-4" data-controller="quantity-selector">
                  <div class="flex items-baseline justify-between">
                    <p class="text-sm font-semibold text-ink-900"><%= variant.name.capitalize %></p>
                    <p class="text-sm text-ink-500"><%= number_to_currency(variant.price_euros, unit: "€", separator: ",", delimiter: " ") %> / pers.</p>
                  </div>
                  <%= form_with url: cart_add_path, method: :post, local: true, data: { action: "submit->cart#add" }, class: "mt-3 flex items-center gap-2" do |f| %>
                    <%= f.hidden_field :product_variant_id, value: variant.id %>
                    <%= f.hidden_field :qty, value: 1, data: { quantity_selector_target: "input" } %>
                    <button type="button" data-action="click->quantity-selector#decrement" class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-flour-400 text-ink-700 hover:bg-flour-100"><%= lucide "minus", size: 16, color: "var(--ink-700)" %></button>
                    <span class="inline-flex h-10 min-w-12 items-center justify-center rounded-md bg-flour-100 text-sm font-semibold text-ink-900" data-quantity-selector-target="display">1</span>
                    <button type="button" data-action="click->quantity-selector#increment" class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-flour-400 text-ink-700 hover:bg-flour-100"><%= lucide "plus", size: 16, color: "var(--ink-700)" %></button>
                    <button type="submit" class="ml-auto inline-flex items-center gap-2 rounded-md bg-ember-600 px-4 py-2 text-sm font-semibold text-white hover:bg-ember-500">Ajouter</button>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="rounded-2xl border border-flour-300 bg-warm-white p-10 text-center">
      <p class="text-lg font-semibold text-ink-900">Nos événements arrivent bientôt.</p>
      <p class="mt-2 text-sm text-ink-600">Aucune réservation de Pizza Party n'est ouverte pour le moment.</p>
      <%= link_to "Voir la boutique", catalog_path, class: "mt-6 inline-flex items-center gap-2 rounded-md bg-ember-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-ember-500" %>
    </div>
  <% end %>
</div>
