<!DOCTYPE html>
<html lang="fr" class="light">
  <head>
    <title><%= content_for(:title) || "Tranches de Vie" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%# En prod/dev, csrf_meta_tags rend le vrai token. En test, la protection CSRF
        est désactivée (allow_forgery_protection = false) → csrf_meta_tags ne rend
        RIEN, ce qui fait planter le JS lisant meta[name="csrf-token"].content
        (connexion OTP, checkout). On injecte alors un meta factice — jamais vérifié
        côté serveur — pour que les system specs pilotent le vrai JS (#126). %>
    <% if protect_against_forgery? %>
      <%= csrf_meta_tags %>
    <% else %>
      <meta name="csrf-param" content="authenticity_token">
      <meta name="csrf-token" content="test-token">
    <% end %>
    <%= csp_meta_tag %>
    <meta name="stripe-key" content="<%= ENV['STRIPE_PUBLIC_KEY'] %>">

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;600;700&family=Hanken+Grotesk:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">

    <!-- Charger Stripe.js globalement pour eviter les erreurs "Stripe is not defined" avec Turbo -->
    <%# En test système, on ne charge PAS le vrai Stripe.js (aucun appel réseau) :
        un shim window.Stripe est injecté à la place (cf. #126). %>
    <% if Rails.env.test? %>
      <%= render "layouts/stripe_test_stub" %>
    <% else %>
      <script src="https://js.stripe.com/v3/"></script>
    <% end %>

    <%= render "layouts/sentry_browser" %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-flour-100 font-sans text-ink-700 antialiased tdv-storefront" data-controller="cart mobile-menu">
    <div data-controller="toast" class="pointer-events-none fixed inset-x-0 top-4 z-50 flex flex-col items-center px-4 sm:px-0">
      <div data-toast-target="container" class="flex w-full max-w-sm flex-col gap-3"></div>
    </div>

    <div class="flex min-h-screen flex-col">
      <header class="border-b border-flour-300 bg-warm-white">
        <div class="mx-auto flex max-w-[1040px] items-center gap-4 px-5 py-4 sm:px-6">
          <%= link_to "Tranches de Vie", catalog_path, class: "whitespace-nowrap font-script text-3xl font-bold leading-none text-sage-700 transition-colors hover:text-sage-600" %>

          <% cart_count = current_cart_count %>
          <div class="ml-auto flex items-center gap-5 sm:gap-6">
            <nav class="hidden items-center gap-7 md:flex">
              <%= link_to "Commander", catalog_path, class: "text-[15px] font-medium leading-none text-ink-700 transition-colors hover:text-ink-900" %>
              <% if customer_signed_in? %>
                <%= link_to "Calendrier", calendar_path, class: "text-[15px] font-medium leading-none text-ink-700 transition-colors hover:text-ink-900" %>
              <% end %>
              <%= link_to "À propos", a_propos_path, class: "text-[15px] font-medium leading-none text-ink-700 transition-colors hover:text-ink-900" %>
              <% if customer_signed_in? %>
                <%= link_to "Mon compte", customers_account_path, class: "text-[15px] font-medium leading-none text-ink-700 transition-colors hover:text-ink-900" %>
              <% else %>
                <%= link_to "Connexion", customer_login_path, class: "text-[15px] font-medium leading-none text-ink-700 transition-colors hover:text-ink-900" %>
              <% end %>
            </nav>

            <div class="relative hidden md:block" data-cart-target="miniCartWrapper" data-action="mouseenter->cart#openMiniCart mouseleave->cart#scheduleMiniCartClose">
              <%= link_to cart_path,
                          class: "flex h-10 items-center gap-2 rounded-md border border-flour-400 bg-warm-white px-3.5 text-sm font-semibold text-ink-900 shadow-xs transition hover:bg-warm-white-2",
                          data: { action: "focus->cart#openMiniCart blur->cart#scheduleMiniCartClose" } do %>
                <%= lucide "shopping-basket", size: 18, color: "var(--ink-900)" %>
                <span class="sr-only">Panier</span>
                <span data-cart-target="count" class="inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-sage-600 px-1.5 text-xs font-bold text-white <%= 'hidden' if cart_count.zero? %>">
                  <%= cart_count %>
                </span>
              <% end %>
              <div data-cart-target="miniCartPanel" class="cart-mini-panel absolute right-0 z-[1000] mt-3 hidden w-80 rounded-lg border border-flour-300 bg-warm-white p-4 shadow-lg" data-action="mouseenter->cart#cancelMiniCartClose mouseleave->cart#scheduleMiniCartClose">
                <div data-cart-target="miniCartContent">
                  <%= render "cart/mini_cart", items: current_cart_items, total_cents: current_cart_total_cents, subtotal_cents: current_cart_subtotal_cents, discount_cents: current_cart_discount_cents, customer: current_customer_for_cart, count: current_cart_count %>
                </div>
              </div>
            </div>

            <button type="button" data-mobile-menu-target="button" data-action="click->mobile-menu#toggle" class="flex h-10 items-center justify-center rounded-md px-2 text-ink-700 md:hidden">
              <%= lucide "menu", size: 24, color: "var(--ink-700)" %>
              <span class="sr-only">Ouvrir la navigation</span>
            </button>
          </div>
        </div>
      </header>

      <!-- Menu mobile -->
      <div data-mobile-menu-target="menu" class="fixed inset-0 z-50 hidden bg-warm-white md:hidden">
        <div class="flex h-full flex-col">
          <div class="flex items-center justify-between border-b border-flour-300 px-5 py-4">
            <span class="font-script text-2xl font-bold text-sage-700">Tranches de Vie</span>
            <button type="button" data-action="click->mobile-menu#close" class="flex h-10 items-center justify-center rounded-md px-2 text-ink-700">
              <%= lucide "x", size: 24, color: "var(--ink-700)" %>
              <span class="sr-only">Fermer la navigation</span>
            </button>
          </div>
          <nav class="flex flex-1 flex-col gap-1 overflow-y-auto px-4 py-4">
            <%= link_to "Commander", catalog_path, class: "rounded-md px-4 py-3 text-base font-medium text-ink-900 hover:bg-flour-100", data: { action: "click->mobile-menu#close" } %>
            <% if customer_signed_in? %>
              <%= link_to "Calendrier", calendar_path, class: "rounded-md px-4 py-3 text-base font-medium text-ink-900 hover:bg-flour-100", data: { action: "click->mobile-menu#close" } %>
            <% end %>
            <%= link_to "À propos", a_propos_path, class: "rounded-md px-4 py-3 text-base font-medium text-ink-900 hover:bg-flour-100", data: { action: "click->mobile-menu#close" } %>
            <% if customer_signed_in? %>
              <%= link_to "Mon compte", customers_account_path, class: "rounded-md px-4 py-3 text-base font-medium text-ink-900 hover:bg-flour-100", data: { action: "click->mobile-menu#close" } %>
              <%= button_to "Déconnexion",
                    customer_logout_path,
                    method: :delete,
                    form: { class: "inline" },
                    class: "w-full cursor-pointer rounded-md border-0 bg-transparent px-4 py-3 text-left text-base font-medium text-ink-900 hover:bg-flour-100",
                    data: { action: "click->mobile-menu#close" } %>
            <% else %>
              <%= link_to "Connexion", customer_login_path, class: "rounded-md px-4 py-3 text-base font-medium text-ink-900 hover:bg-flour-100", data: { action: "click->mobile-menu#close" } %>
            <% end %>
            <div class="mt-4 border-t border-flour-300 pt-4">
              <%= link_to cart_path, class: "flex items-center justify-between rounded-md px-4 py-3 text-base font-medium text-ink-900 hover:bg-flour-100", data: { action: "click->mobile-menu#close" } do %>
                <span class="flex items-center gap-3">
                  <%= lucide "shopping-basket", size: 20, color: "var(--ink-700)" %>
                  <span>Panier</span>
                </span>
                <span class="inline-flex h-6 min-w-6 items-center justify-center rounded-full bg-sage-600 px-2 text-xs font-bold text-white <%= 'hidden' if cart_count.zero? %>">
                  <%= cart_count %>
                </span>
              <% end %>
            </div>
          </nav>
        </div>
      </div>

      <% if notice.present? || alert.present? %>
        <div class="mx-auto w-full max-w-[1040px] px-4 pt-6 sm:px-6">
          <% if notice.present? %>
            <div class="flex items-start gap-3 rounded-md border border-success-200 bg-success-100 px-4 py-3 text-sm font-medium text-success-700">
              <%= lucide "check", size: 18, color: "var(--success-600)", css: "mt-0.5" %>
              <span><%= notice %></span>
            </div>
          <% end %>
          <% if alert.present? %>
            <div class="mt-3 flex items-start gap-3 rounded-md border border-danger-200 bg-danger-100 px-4 py-3 text-sm font-medium text-danger-700">
              <%= lucide "alert-triangle", size: 18, color: "var(--danger-600)", css: "mt-0.5" %>
              <span><%= alert %></span>
            </div>
          <% end %>
        </div>
      <% end %>

      <main class="flex-1 pb-24 md:pb-12">
        <% if content_for?(:full_bleed) %>
          <%= yield %>
        <% else %>
          <div class="mx-auto w-full max-w-[1040px] px-4 py-8 sm:px-6">
            <%= yield %>
          </div>
        <% end %>
      </main>

      <% foot_link = "text-[14px] text-flour-100/80 transition-colors hover:text-flour-100" %>
      <% foot_head = "mb-4 text-[13px] font-semibold uppercase tracking-[0.07em] text-flour-300 opacity-70" %>
      <footer class="bg-ink-900 text-flour-100">
        <div class="mx-auto max-w-[1040px] px-6 pb-7 pt-13">
          <div class="grid gap-10 md:grid-cols-[1.6fr_1fr_1fr_1.1fr]">
            <div>
              <div class="mb-3.5 font-script text-[32px] font-bold leading-none text-flour-50">Tranches de Vie</div>
              <p class="mb-[18px] max-w-[300px] text-[14px] leading-relaxed text-flour-200 opacity-85">Pain au levain naturel, cuit au feu de bois dans la vallée du Bocq. Farines locales, longues fermentations, pétrissage à la main.</p>
              <div class="inline-flex items-center gap-2 rounded-full bg-white/[0.08] px-3 py-1.5 text-xs font-semibold tracking-[0.03em] text-flour-100">
                <%= lucide "flame", size: 14, color: "#e8956b" %> Cuit au feu de bois
              </div>
            </div>

            <div>
              <div class="<%= foot_head %>">La boulangerie</div>
              <div class="flex flex-col gap-2.5">
                <%= link_to "Nos pains et compagnie", catalog_path, class: foot_link %>
                <%= link_to "Calendrier", calendar_path, class: foot_link %>
                <%= link_to "À propos", a_propos_path, class: foot_link %>
                <%= link_to "Mon compte", (customer_signed_in? ? customers_account_path : customer_login_path), class: foot_link %>
              </div>
            </div>

            <div>
              <div class="<%= foot_head %>">Commander</div>
              <div class="flex flex-col gap-2.5">
                <%= link_to "Mon panier", cart_path, class: foot_link %>
                <%= link_to "Mon portefeuille", customers_wallet_path, class: foot_link %>
                <%= link_to "Planifier une commande", calendar_path, class: foot_link %>
              </div>
            </div>

            <div>
              <div class="<%= foot_head %>">Le point de retrait</div>
              <div class="flex flex-col gap-3">
                <span class="inline-flex items-start gap-2.5 text-[14px] leading-snug text-flour-100 opacity-85"><span class="mt-0.5 flex-shrink-0"><%= lucide "map-pin", size: 16, color: "var(--sage-300)" %></span><span>Les 4 Sources<br>Entre Yvoir et Crupet</span></span>
                <span class="inline-flex items-center gap-2.5 text-[14px] text-flour-100 opacity-85"><%= lucide "clock", size: 16, color: "var(--sage-300)" %> Le jour de cuisson ou le lendemain</span>
                <a href="mailto:boulangerie@les4sources.be" class="inline-flex items-center gap-2.5 text-[14px] text-flour-100 opacity-85 hover:opacity-100"><%= lucide "mail", size: 16, color: "var(--sage-300)" %> boulangerie@les4sources.be</a>
                <a href="https://www.les4sources.be/a-propos/acces-ahinvaux" target="_blank" rel="noopener" class="inline-flex items-center gap-2.5 text-[14px] font-medium text-sage-300 hover:underline"><%= lucide "navigation", size: 16, color: "var(--sage-300)" %> Accès et itinéraire</a>
              </div>
            </div>
          </div>

          <div class="my-[18px] mt-[34px] h-px bg-white/10"></div>

          <div class="flex flex-wrap items-center justify-between gap-4 text-[13px] leading-snug text-flour-200 opacity-70">
            <span>Pains produits avec amour et passion dans la vallée du Bocq</span>
            <div class="flex gap-5">
              <%= link_to "Conditions générales", cgv_path, class: "text-flour-200 transition-colors hover:text-flour-100" %>
              <%= link_to "Vie privée", vie_privee_path, class: "text-flour-200 transition-colors hover:text-flour-100" %>
            </div>
          </div>
        </div>
      </footer>
    </div>

    <% unless controller_name == 'cart' && action_name == 'show' || controller_name == 'checkout' %>
      <div class="md:hidden">
        <%= link_to cart_path, class: "fixed inset-x-4 bottom-4 z-40 flex items-center justify-between rounded-full bg-sage-700 px-5 py-3 text-white shadow-lg transition hover:bg-sage-600" do %>
          <span class="flex items-center gap-3">
            <%= lucide "shopping-basket", size: 22, color: "#fff" %>
            <span class="text-sm font-semibold uppercase tracking-wide">Voir le panier</span>
          </span>
          <span data-cart-target="count" class="inline-flex min-w-8 items-center justify-center rounded-full bg-white px-2 py-1 text-xs font-bold uppercase text-sage-700 <%= 'hidden' if cart_count.zero? %>">
            <%= cart_count %>
          </span>
        <% end %>
      </div>
    <% end %>
  </body>
</html>
