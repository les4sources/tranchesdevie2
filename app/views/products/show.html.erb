<% content_for :title, @product.name %>

<div class="w-full">
  <!-- Breadcrumbs -->
  <nav aria-label="Breadcrumb" class="mb-8">
    <ol class="flex flex-wrap items-center gap-2 text-sm text-ink-500">
      <li><%= link_to "Accueil", root_path, class: "hover:text-ink-700" %></li>
      <li><%= lucide "chevron-right", size: 14, color: "var(--ink-400)" %></li>
      <li><%= link_to "Nos pains et compagnie", catalog_path, class: "hover:text-ink-700" %></li>
      <li><%= lucide "chevron-right", size: 14, color: "var(--ink-400)" %></li>
      <li><span class="font-medium text-ink-700"><%= product_category_heading(@product.category) %></span></li>
      <li><%= lucide "chevron-right", size: 14, color: "var(--ink-400)" %></li>
      <li><span class="font-medium text-ink-900" aria-current="page"><%= @product.name %></span></li>
    </ol>
  </nav>

  <div class="lg:grid lg:grid-cols-2 lg:items-start lg:gap-x-10">
    <!-- Image gallery -->
    <div class="flex flex-col-reverse" data-controller="product-carousel" data-action="touchstart->product-carousel#touchStart touchmove->product-carousel#touchMove touchend->product-carousel#touchEnd">
      <!-- Image selector -->
      <% if @product_images.length > 1 %>
        <div class="mx-auto mt-6 hidden w-full max-w-2xl sm:block lg:max-w-none">
          <div class="grid grid-cols-4 gap-4" aria-label="Sélection d'image">
            <% @product_images.each_with_index do |image_data, index| %>
              <button
                type="button"
                class="relative flex h-24 cursor-pointer items-center justify-center overflow-hidden rounded-md bg-warm-white ring-offset-2 focus:outline-none focus:ring-2 focus:ring-sage-600 <%= index == 0 ? "ring-2 ring-sage-600" : "ring-0" %>"
                data-product-carousel-target="thumbnail"
                data-action="click->product-carousel#goToSlide"
                data-carousel-index="<%= index %>"
              >
                <span class="sr-only">Image <%= index + 1 %></span>
                <div class="absolute inset-0 overflow-hidden rounded-md">
                  <img src="<%= image_data[:url] %>" alt="<%= @product.name %> - Image <%= index + 1 %>" class="h-full w-full object-cover object-center">
                </div>
              </button>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Main image carousel -->
      <div class="relative aspect-square w-full overflow-hidden rounded-xl bg-flour-200 shadow-sm">
        <% @product_images.each_with_index do |image_data, index| %>
          <div class="carousel-slide absolute inset-0 bg-cover bg-center transition-opacity duration-500" data-product-carousel-target="slide" style="background-image: url('<%= image_data[:url] %>'); opacity: <%= index == 0 ? '1' : '0' %>;"></div>
        <% end %>

        <!-- Navigation dots for mobile -->
        <% if @product_images.length > 1 %>
          <div class="absolute bottom-4 left-1/2 z-10 flex -translate-x-1/2 gap-3">
            <% @product_images.each_with_index do |_, index| %>
              <button type="button" class="carousel-dot h-3 w-3 rounded-full transition-all <%= index == 0 ? "bg-white" : "bg-white/60" %>" data-product-carousel-target="dot" data-action="click->product-carousel#goToSlide" data-carousel-index="<%= index %>" aria-label="Image <%= index + 1 %>"></button>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Product info -->
    <div class="mt-10 sm:mt-16 lg:mt-0">
      <h1 class="text-3xl font-bold tracking-tight text-ink-900"><%= @product.name %></h1>

      <div class="mt-2">
        <span class="inline-flex items-center rounded-full bg-flour-200 px-2.5 py-0.5 text-xs font-semibold text-ink-700">
          <%= ProductDecorator.decorate(@product).channel_label %>
        </span>
      </div>

      <div class="mt-3">
        <p class="text-3xl font-bold tracking-tight text-ink-900" data-price-display>
          <%= number_to_currency(@selected_variant.price_euros, unit: "€", separator: ",", delimiter: "") %>
        </p>
      </div>

      <div class="mt-6 flex items-start gap-2 rounded-md border-l-4 border-sage-300 bg-sage-100 px-4 py-3 text-sm text-sage-700">
        <span class="mt-0.5 flex-shrink-0"><%= lucide "info", size: 16, color: "var(--sage-700)" %></span>
        <span>Le choix du <span class="font-semibold">jour de cuisson</span> se fait à l'étape du panier.</span>
      </div>

      <!-- Description -->
      <div class="mt-6">
        <p class="text-base leading-relaxed text-ink-700">
          <%= @product.description %>
        </p>
        <% if @product.pizza_party_role_party? %>
          <p class="mt-2 text-xs text-ink-500">Nous comptons 1 boule de pâte à pizza / personne</p>
        <% end %>
      </div>

      <!-- Availability -->
      <div class="mt-4">
        <div class="flex items-center gap-2 text-sm text-sage-700">
          <%= lucide "check", size: 18, color: "var(--sage-700)" %>
          <span>En stock et prêt à être commandé</span>
        </div>
      </div>

      <!-- Variant selection -->
      <div class="mt-8">
        <h2 class="sr-only">Poids</h2>
        <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2"<% if @variants.length > 1 %> data-controller="variant-selector"<% end %>>
          <% @variants.each do |variant| %>
            <label class="relative flex rounded-lg border p-4 focus:outline-none <%= "cursor-pointer" if @variants.length > 1 %> <%= "cursor-default opacity-75" if @variants.length == 1 %> <%= "border-sage-600 bg-sage-100" if variant.id == @selected_variant.id %> <%= "border-flour-300 hover:bg-flour-100" if @variants.length > 1 && variant.id != @selected_variant.id %> <%= "border-flour-300" if @variants.length == 1 %>"<% if @variants.length > 1 %> data-variant-selector-target="option" data-action="click->variant-selector#select"<% end %> data-variant-id="<%= variant.id %>" data-variant-price="<%= variant.price_euros %>">
              <input type="radio" name="variant" value="<%= variant.id %>" class="sr-only" <%= "checked" if variant.id == @selected_variant.id %> <%= "disabled" if @variants.length == 1 %>>
              <div class="flex flex-1">
                <div class="flex flex-col">
                  <span class="block text-sm font-semibold text-ink-900"><%= variant.name %></span>
                  <span class="mt-1 block text-sm text-ink-500"><%= number_to_currency(variant.price_euros, unit: "€", separator: ",", delimiter: "") %></span>
                  <% restriction = ProductVariantDecorator.decorate(variant).weekday_restriction_label %>
                  <% if restriction %><span class="mt-1 block text-xs font-medium text-warning-700"><%= restriction %></span><% end %>
                </div>
              </div>
              <% if variant.id == @selected_variant.id %>
                <span class="material-symbols-outlined absolute right-4 top-4 text-sage-700">check_circle</span>
              <% end %>
              <span class="pointer-events-none absolute -inset-px rounded-lg border-2 <%= "border-sage-600" if variant.id == @selected_variant.id %>" aria-hidden="true"></span>
            </label>
          <% end %>
        </div>
      </div>

      <!-- Add to cart form -->
      <div class="mt-8" data-controller="quantity-selector">
        <%= form_with url: cart_add_path, method: :post, local: true, data: { action: "submit->cart#add" }, class: "flex flex-col gap-4" do |f| %>
          <%= f.hidden_field :product_variant_id, value: @selected_variant.id, data: { variant_selector_target: "variantInput" } %>
          <%= f.hidden_field :qty, value: 1, data: { quantity_selector_target: "input" } %>

          <!-- Quantity selector -->
          <% quantity_label = @product.pizza_party_role_party? ? "Nombre de personnes" : "Quantité" %>
          <div>
            <label class="sr-only"><%= quantity_label %></label>
            <div class="flex items-center gap-3">
              <span class="text-sm font-medium text-ink-900"><%= quantity_label %></span>
              <div class="flex items-center gap-2">
                <button type="button" data-action="click->quantity-selector#decrement" class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-flour-400 text-ink-700 transition hover:bg-flour-100 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]">
                  <%= lucide "minus", size: 16, color: "var(--ink-700)" %>
                </button>
                <span class="inline-flex h-10 min-w-12 items-center justify-center rounded-md bg-flour-100 text-sm font-semibold text-ink-900" data-quantity-selector-target="display">
                  1
                </span>
                <button type="button" data-action="click->quantity-selector#increment" class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-flour-400 text-ink-700 transition hover:bg-flour-100 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]">
                  <%= lucide "plus", size: 16, color: "var(--ink-700)" %>
                </button>
              </div>
            </div>
          </div>

          <button type="submit" class="flex w-full items-center justify-center rounded-md bg-ember-600 px-6 py-3 text-base font-semibold text-white shadow-xs transition hover:bg-ember-500 focus:outline-none focus:ring-[3px] focus:ring-[color:var(--focus-ring)]">
            Ajouter dans mon panier
          </button>
        <% end %>
      </div>

      <!-- Guarantee -->
      <div class="mt-6 space-y-2">
        <% [ "Ingrédients bio", "Cuit au feu de bois", "Préparé avec amour" ].each do |label| %>
          <div class="flex items-center gap-2 text-sm text-ink-500">
            <%= lucide "shield-check", size: 18, color: "var(--sage-600)" %>
            <span><%= label %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
